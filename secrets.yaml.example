# Copy this file to secrets.yaml and fill in your own values.
# Never commit secrets.yaml to git — it's in .gitignore for a reason.

wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

ap_password: "fallback-ap-password"

# Generate a new key for each ESPHome project:
# https://esphome.io/components/api.html#configuration-variables
api_key: "generate-with-esphome-or-base64-32-bytes"
